#  Mission Planner Ekran Yakalama Widget
# ─────────────────────────────────────────────
class MissionPlannerMapWidget(QWidget):
    """
    Mission Planner penceresi açıkken harita bölümünü gerçek zamanlı yakalar
    ve buraya yansıtır. MP'nin sol kontrol paneli (~258px) kırpılır, sadece
    harita görünür — tıpkı MP'yi doğrudan izlemek gibi.
    """

    # MP sol panel genişliği (HUD + sekme alanı). Ayarlanabilir.
    MP_LEFT_PANEL_PX = 258

    def __init__(self, parent=None):
        super().__init__(parent)
        self._hwnd         = None      # Mission Planner pencere handle
        self._sct          = None      # mss bağlamı
        self._last_pixmap  = None
        self._fps_label    = ""
        self._status       = "Mission Planner penceresi aranıyor..."
        self._capture_ok   = False

        self.setMinimumWidth(400)
        self.setStyleSheet("background:#111;")

        # Ana layout
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)

        # Görüntü etiketi
        self._img_label = QLabel()
        self._img_label.setAlignment(Qt.AlignCenter)
        self._img_label.setStyleSheet("background:#111;")
        self._img_label.setSizePolicy(QSizePolicy.Expanding, QSizePolicy.Expanding)
        layout.addWidget(self._img_label, stretch=1)

        # Alt durum çubuğu
        self._status_bar = QLabel()
        self._status_bar.setFixedHeight(22)
        self._status_bar.setAlignment(Qt.AlignVCenter | Qt.AlignLeft)
        self._status_bar.setStyleSheet(
            "background:#0d0d1a; color:#888; font-family:'Courier New';"
            "font-size:11px; padding:0 8px; border-top:1px solid #1a1a3a;")
        layout.addWidget(self._status_bar)

        # mss bağlamını başlat
        if HAS_MSS:
            try:
                self._sct = mss.mss()
            except Exception:
                pass

        # Pencere arama zamanlayıcısı (her 3s)
        self._find_timer = QTimer()
        self._find_timer.timeout.connect(self._find_mp_window)
        self._find_timer.start(3000)
        self._find_mp_window()

        # Yakalama zamanlayıcısı (~15fps)
        self._cap_timer = QTimer()
        self._cap_timer.timeout.connect(self._capture_frame)
        self._cap_timer.start(67)

    # ── Mission Planner penceresini bul ───────────────────────────────────
    def _find_mp_window(self):
        if not HAS_WIN32:
            self._status = ("⚠  pywin32 kurulu değil.  "
                            "Kurmak için:  pip install pywin32")
            self._update_status()
            return

        found = []
        def _cb(hwnd, _):
            if win32gui.IsWindowVisible(hwnd):
                title = win32gui.GetWindowText(hwnd)
                if 'Mission Planner' in title:
                    found.append(hwnd)
        try:
            win32gui.EnumWindows(_cb, None)
        except Exception:
            pass

        if found:
            self._hwnd = found[0]
            title = win32gui.GetWindowText(self._hwnd)
            self._status = f"✔  Bağlı: {title}"
            self._capture_ok = True
        else:
            self._hwnd = None
            self._capture_ok = False
            self._status = "⏳  Mission Planner penceresi bulunamadı — açık olduğundan emin olun"
            self._show_placeholder()
        self._update_status()

    # ── Kare yakala ve göster ─────────────────────────────────────────────
    def _capture_frame(self):
        if not self._hwnd or not self._sct:
            return
        if not HAS_WIN32:
            return

        try:
            # Pencere konumunu al
            rect = win32gui.GetWindowRect(self._hwnd)
            wx, wy, wx2, wy2 = rect
            ww = wx2 - wx
            wh = wy2 - wy

            if ww < 100 or wh < 100:   # minimize edilmiş
                return

            # Harita bölgesi: MP sol panel kırpıldıktan sonra
            map_x = wx + self.MP_LEFT_PANEL_PX
            map_w = ww - self.MP_LEFT_PANEL_PX
            if map_w < 50:
                return

            monitor = {
                "top":    wy,
                "left":   map_x,
                "width":  map_w,
                "height": wh,
            }

            shot = self._sct.grab(monitor)

            # BGRA bytes → QImage (kopyalama yapmadan)
            raw = bytes(shot.bgra)
            qimg = QImage(raw, shot.width, shot.height,
                          shot.width * 4, QImage.Format_ARGB32)
            pixmap = QPixmap.fromImage(qimg)

            # Widget boyutuna ölçekle
            label_size = self._img_label.size()
            if label_size.width() > 0 and label_size.height() > 0:
                scaled = pixmap.scaled(label_size,
                                       Qt.KeepAspectRatio,
                                       Qt.FastTransformation)
                self._img_label.setPixmap(scaled)

        except Exception as e:
            # Pencere kapandıysa yeniden ara
            self._hwnd = None
            self._capture_ok = False
            self._status = f"⚠  Bağlantı koptu: {e}"
            self._update_status()
            self._show_placeholder()

    def _show_placeholder(self):
        """Pencere bulunamadığında bilgilendirme ekranı göster."""
        w = max(self._img_label.width(), 400)
        h = max(self._img_label.height(), 300)
        px = QPixmap(w, h)
        px.fill(QColor("#0a0a1a"))

        p = QPainter(px)
        p.setRenderHint(QPainter.Antialiasing)

        # Dış çerçeve
        p.setPen(QPen(QColor("#0f3460"), 2))
        p.setBrush(Qt.NoBrush)
        p.drawRoundedRect(20, 20, w - 40, h - 40, 12, 12)

        # İkon ve metin
        p.setPen(QColor("#e74c3c"))
        p.setFont(QFont("Arial", 32))
        p.drawText(QRectF(0, h / 2 - 80, w, 50), Qt.AlignCenter, "📡")

        p.setPen(QColor("#a0c4ff"))
        p.setFont(QFont("Arial", 13, QFont.Bold))
        p.drawText(QRectF(0, h / 2 - 20, w, 30),
                   Qt.AlignCenter, "Mission Planner Bekleniyor")

        p.setPen(QColor("#555"))
        p.setFont(QFont("Arial", 10))
        p.drawText(QRectF(0, h / 2 + 18, w, 24),
                   Qt.AlignCenter, "Mission Planner açıldığında harita otomatik görünecek")

        if not HAS_MSS:
            p.setPen(QColor("#f39c12"))
            p.setFont(QFont("Arial", 10))
            p.drawText(QRectF(0, h / 2 + 50, w, 24),
                       Qt.AlignCenter, "⚠  mss kurulu değil → pip install mss")
        if not HAS_WIN32:
            p.setPen(QColor("#f39c12"))
            p.setFont(QFont("Arial", 10))
            p.drawText(QRectF(0, h / 2 + 78, w, 24),
                       Qt.AlignCenter, "⚠  pywin32 kurulu değil → pip install pywin32")

        p.end()
        self._img_label.setPixmap(px)

    def _update_status(self):
        self._status_bar.setText(self._status)

    def resizeEvent(self, event):
        super().resizeEvent(event)
        if not self._capture_ok:
            self._show_placeholder()

    def closeEvent(self, event):
        if self._sct:
            try:
                self._sct.close()
            except Exception:
                pass
        super().closeEvent(event)


# ─────────────────────────────────────────────
#  Thread Sınıfları
# ─────────────────────────────────────────────
class ConnectThread(QThread):
    result = Signal(bool, str)
    def __init__(self, mav, conn_str):
        super().__init__(); self.mav = mav; self.conn_str = conn_str
    def run(self):
        self.mav.connection_string = self.conn_str
        ok = self.mav.connect()
        self.result.emit(ok, "Baglanti basarili!" if ok else "Baglanti basarisiz.")

class SetModeThread(QThread):
    result = Signal(bool, str)
    def __init__(self, mav, mode):
        super().__init__(); self.mav = mav; self.mode = mode
    def run(self):
        ok, msg = self.mav.set_mode(self.mode)
        self.result.emit(ok, msg)

class ArmThread(QThread):
    result = Signal(bool, str)
    def __init__(self, mav):
        super().__init__(); self.mav = mav
    def run(self):
        ok, msg = self.mav.arm()
        self.result.emit(ok, msg)

class DisarmThread(QThread):
    result = Signal(bool, str)
    def __init__(self, mav):
        super().__init__(); self.mav = mav
    def run(self):
        ok, msg = self.mav.disarm()
        self.result.emit(ok, msg)


