class AttitudeWidget(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.roll  = 0.0
        self.pitch = 0.0
        self.setMinimumSize(180, 180)

    def set_attitude(self, roll, pitch):
        self.roll  = roll
        self.pitch = pitch
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        w  = self.width();  h  = self.height()
        cx = w / 2;         cy = h / 2
        r  = min(w, h) / 2 - 10

        clip_path = QPainterPath()
        clip_path.addEllipse(QPointF(cx, cy), r, r)
        painter.setClipPath(clip_path)

        painter.save()
        painter.translate(cx, cy)
        painter.rotate(-self.roll)
        pitch_offset = self.pitch * 2

        painter.setBrush(QBrush(QColor("#1a6fa8")))
        painter.setPen(Qt.NoPen)
        painter.drawRect(int(-r), int(-r * 2), int(r * 2), int(r * 2 + pitch_offset))
        painter.setBrush(QBrush(QColor("#8b5e3c")))
        painter.drawRect(int(-r), int(pitch_offset), int(r * 2), int(r * 2))
        painter.setPen(QPen(QColor("white"), 2))
        painter.drawLine(QPointF(-r, pitch_offset), QPointF(r, pitch_offset))
        painter.setPen(QPen(QColor("white"), 1))
        painter.setFont(QFont("Arial", 7))
        for deg in range(-30, 31, 10):
            if deg == 0: continue
            y_off  = pitch_offset - deg * 2
            line_w = 28 if deg % 20 == 0 else 16
            painter.drawLine(QPointF(-line_w, y_off), QPointF(line_w, y_off))
            painter.drawText(QRectF(line_w + 3, y_off - 6, 20, 12),
                             Qt.AlignLeft | Qt.AlignVCenter, str(abs(deg)))
        painter.restore()
        painter.setClipping(False)

        painter.setBrush(Qt.NoBrush)
        painter.setPen(QPen(QColor("#0f3460"), 3))
        painter.drawEllipse(QPointF(cx, cy), r, r)
        painter.setPen(QPen(QColor("#f1c40f"), 2))
        painter.drawLine(QPointF(cx - 30, cy), QPointF(cx - 10, cy))
        painter.drawLine(QPointF(cx + 10, cy), QPointF(cx + 30, cy))
        painter.drawLine(QPointF(cx, cy - 8), QPointF(cx, cy + 8))
        painter.setBrush(QBrush(QColor("#f1c40f")))
        painter.setPen(Qt.NoPen)
        painter.drawEllipse(QPointF(cx, cy), 4, 4)

        painter.setPen(QColor("white"))
        painter.setFont(QFont("Arial", 8, QFont.Bold))
        painter.drawText(QRectF(cx - r, cy + r - 22, r - 4, 18),
                         Qt.AlignRight | Qt.AlignVCenter, f"R:{self.roll:.1f}")
        painter.drawText(QRectF(cx + 4, cy + r - 22, r - 4, 18),
                         Qt.AlignLeft | Qt.AlignVCenter, f"P:{self.pitch:.1f}")
        painter.setPen(QColor("#a0c4ff"))
        painter.setFont(QFont("Arial", 9, QFont.Bold))
        painter.drawText(QRectF(cx - 60, cy - r + 4, 120, 18),
                         Qt.AlignCenter, "YAPAY UFUK")


