        splitter.setStretchFactor(0, 0)
        splitter.setStretchFactor(1, 1)

        root.addWidget(splitter)

        # Status bar
        self.status_bar = self.statusBar()
        self.status_bar.showMessage("Bagli degil.")
        self.hb_label = QLabel("Sinyal yok")
        self.hb_label.setStyleSheet("color:#888; padding-right:10px;")
        self.status_bar.addPermanentWidget(self.hb_label)

        self.hb_timer = QTimer()
        self.hb_timer.timeout.connect(self._check_heartbeat)
        self.hb_timer.start(2000)

        self.cleanup_timer = QTimer()
        self.cleanup_timer.timeout.connect(self._cleanup_threads)
        self.cleanup_timer.start(3000)

    # ── Bağlantı ───────────────────────────────────────────────────────────
    def connect_clicked(self):
        conn_str = self.conn_input.text().strip()
        self.status_bar.showMessage("Baglaniliyor...")
        self.connect_btn.setEnabled(False)
        self.conn_thread = ConnectThread(self.mav, conn_str)
        self.conn_thread.result.connect(self._on_connect_result)
        self.conn_thread.start()

    def _on_connect_result(self, ok, msg):
        self.status_bar.showMessage(msg)
        if ok:
            self.disconnect_btn.setEnabled(True)
            for btn in self.mode_buttons_dict.values():
                btn.setEnabled(True)
            self.custom_apply_btn.setEnabled(True)
            self.arm_btn.setEnabled(True)
            self.disarm_btn.setEnabled(True)
        else:
            self.connect_btn.setEnabled(True)
            QMessageBox.critical(self, "Baglanti Hatasi", msg)

    def disconnect_clicked(self):
        self.mav.disconnect()
        self.connect_btn.setEnabled(True)
        self.disconnect_btn.setEnabled(False)
        for btn in self.mode_buttons_dict.values():
            btn.setEnabled(False)
        self.custom_apply_btn.setEnabled(False)
        self.arm_btn.setEnabled(False)
        self.disarm_btn.setEnabled(False)
        self.current_mode_label.setText("---")
        self.status_bar.showMessage("Baglanti kesildi.")
        self.hb_label.setText("Sinyal yok")
        self.hb_label.setStyleSheet("color:#888; padding-right:10px;")

    def set_mode_clicked(self, mode):
        if not mode:
            return
        self.status_bar.showMessage(f"Mod degistiriliyor: {mode}...")
        t = SetModeThread(self.mav, mode)
        t.result.connect(self._on_set_mode_result)
        t.start()
        self._threads.append(t)

    def _on_set_mode_result(self, ok, msg):
        self.status_bar.showMessage(msg)
        if not ok:
            QMessageBox.warning(self, "Mod Degistirme Hatasi", msg)

    def arm_clicked(self):
        if QMessageBox.question(self, "ARM Onayi",
            "Ucagi ARM etmek istediginizden emin misiniz?",
            QMessageBox.Yes | QMessageBox.No) == QMessageBox.Yes:
            t = ArmThread(self.mav)
            t.result.connect(self._on_arm_result)
            t.start()
            self._threads.append(t)

    def disarm_clicked(self):
        if QMessageBox.question(self, "DISARM Onayi",
            "Ucagi DISARM etmek istediginizden emin misiniz?",
            QMessageBox.Yes | QMessageBox.No) == QMessageBox.Yes:
            t = DisarmThread(self.mav)
            t.result.connect(self._on_arm_result)
            t.start()
            self._threads.append(t)

    def _on_arm_result(self, ok, msg):
        self.status_bar.showMessage(msg)
        if not ok:
            QMessageBox.warning(self, "Hata", msg)

    def _update_mode_display(self, mode):
        self.current_mode_label.setText(mode)
        self.status_bar.showMessage(f"Aktif mod: {mode}")

    def _update_telemetry_display(self, data):
        self.airspeed_gauge.set_value(data['airspeed'])
        self.altitude_gauge.set_value(data['altitude'])
        self.attitude_widget.set_attitude(data['roll'], data['pitch'])
        self.status_widget.set_data(
            data['gps_satellites'], data['rssi'], data.get('rssi_active', False))

        if data['armed']:
            self.arm_status_label.setText("ARMED")
            self.arm_status_label.setStyleSheet(
                "color:#27ae60; background:#16213e; border-radius:8px;"
                " padding:8px; font-weight:bold;")
        else:
            self.arm_status_label.setText("DISARMED")
            self.arm_status_label.setStyleSheet(
                "color:#e74c3c; background:#16213e; border-radius:8px;"
                " padding:8px; font-weight:bold;")

    def _check_heartbeat(self):
        if self.mav.connected:
            self.hb_label.setText("BAGLI")
            self.hb_label.setStyleSheet("color:#2ecc71; padding-right:10px;")
        else:
            self.hb_label.setText("Sinyal yok")
            self.hb_label.setStyleSheet("color:#888; padding-right:10px;")

    def _cleanup_threads(self):
        self._threads = [t for t in self._threads if t.isRunning()]

    def closeEvent(self, event):
        self.mav.disconnect()
        for t in self._threads:
            t.wait(2000)
        event.accept()


