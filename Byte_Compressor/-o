class GaugeWidget(QWidget):
    def __init__(self, title, unit, min_val, max_val, parent=None):
        super().__init__(parent)
        self.title   = title
        self.unit    = unit
        self.min_val = min_val
        self.max_val = max_val
        self.value   = min_val
        self.setMinimumSize(180, 180)

    def set_value(self, val):
        self.value = max(self.min_val, min(self.max_val, val))
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        w  = self.width();  h  = self.height()
        cx = w / 2;         cy = h / 2
        r  = min(w, h) / 2 - 10

        painter.setBrush(QBrush(QColor("#16213e")))
        painter.setPen(Qt.NoPen)
        painter.drawEllipse(QPointF(cx, cy), r, r)
        painter.setBrush(Qt.NoBrush)
        painter.setPen(QPen(QColor("#0f3460"), 3))
        painter.drawEllipse(QPointF(cx, cy), r, r)

        arc_rect = QRectF(cx - r + 14, cy - r + 14, (r - 14) * 2, (r - 14) * 2)
        painter.setPen(QPen(QColor("#1a1a2e"), 10, Qt.SolidLine, Qt.RoundCap))
        painter.drawArc(arc_rect, int(225 * 16), int(-270 * 16))

        ratio = max(0.0, min(1.0,
            (self.value - self.min_val) / (self.max_val - self.min_val)))
        arc_color = (QColor("#e74c3c") if ratio > 0.8
                     else QColor("#f39c12") if ratio > 0.6
                     else QColor("#3498db"))
        painter.setPen(QPen(arc_color, 10, Qt.SolidLine, Qt.RoundCap))
        painter.drawArc(arc_rect, int(225 * 16), int(-270 * ratio * 16))

        for i in range(11):
            tick_ratio = i / 10
            angle_rad  = math.radians(225 - 270 * tick_ratio)
            is_major   = (i % 2 == 0)
            r_outer    = r - 18
            r_inner    = r_outer - (12 if is_major else 6)
            painter.setPen(QPen(QColor("#a0c4ff") if is_major else QColor("#555"),
                                2 if is_major else 1))
            painter.drawLine(
                QPointF(cx + r_outer * math.cos(angle_rad),
                        cy - r_outer * math.sin(angle_rad)),
                QPointF(cx + r_inner * math.cos(angle_rad),
                        cy - r_inner * math.sin(angle_rad)))
            if is_major:
                tick_val = self.min_val + tick_ratio * (self.max_val - self.min_val)
                lbl_r = r_outer - 20
                lx = cx + lbl_r * math.cos(angle_rad) - 14
                ly = cy - lbl_r * math.sin(angle_rad) - 8
                painter.setPen(QColor("#ccc"))
                painter.setFont(QFont("Arial", 7))
                painter.drawText(QRectF(lx, ly, 28, 16),
                                 Qt.AlignCenter, f"{int(tick_val)}")

        needle_rad = math.radians(225 - 270 * ratio)
        needle_len = r - 32
        painter.setPen(QPen(QColor("#e74c3c"), 2))
        painter.drawLine(QPointF(cx, cy),
                         QPointF(cx + needle_len * math.cos(needle_rad),
                                 cy - needle_len * math.sin(needle_rad)))
        painter.setBrush(QBrush(QColor("#e74c3c")))
        painter.setPen(Qt.NoPen)
        painter.drawEllipse(QPointF(cx, cy), 5, 5)

        painter.setPen(QColor("white"))
        painter.setFont(QFont("Arial", 13, QFont.Bold))
        painter.drawText(QRectF(cx - 40, cy + r * 0.28, 80, 26),
                         Qt.AlignCenter, f"{self.value:.1f}")
        painter.setPen(QColor("#a0c4ff"))
        painter.setFont(QFont("Arial", 8))
        painter.drawText(QRectF(cx - 30, cy + r * 0.28 + 24, 60, 16),
                         Qt.AlignCenter, self.unit)
        painter.setPen(QColor("#a0c4ff"))
        painter.setFont(QFont("Arial", 9, QFont.Bold))
        painter.drawText(QRectF(cx - 55, cy - r + 6, 110, 18),
                         Qt.AlignCenter, self.title)


