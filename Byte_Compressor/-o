class MainWindow(QMainWindow):
    mode_changed_signal = Signal(str)
    telemetry_signal    = Signal(dict)

    MODES = [
        ("MANUAL",    "#e74c3c", "Manuel kontrol"),
        ("STABILIZE", "#e67e22", "Stabilize"),
        ("FBWA",      "#f1c40f", "Fly-by-Wire A"),
        ("FBWB",      "#f39c12", "Fly-by-Wire B"),
        ("AUTO",      "#2ecc71", "Otomatik gorev"),
        ("RTL",       "#3498db", "Return to Launch"),
        ("LOITER",    "#9b59b6", "Loiter"),
        ("GUIDED",    "#1abc9c", "Guided mod"),
        ("TAKEOFF",   "#27ae60", "Kalkis"),
        ("CIRCLE",    "#8e44ad", "Daire"),
    ]
    EXTRA_MODES = ["CRUISE", "AUTOTUNE", "TRAINING", "ACRO"]

    def __init__(self):
        super().__init__()
        self.mav = MAVLinkConnection()
        self.mav.on_mode_change = self._on_mode_change_callback
        self.mav.on_telemetry   = self._on_telemetry_callback
        self.mode_changed_signal.connect(self._update_mode_display)
        self.telemetry_signal.connect(self._update_telemetry_display)
        self.mode_buttons_dict = {}
        self._threads    = []
        self.conn_thread = None
        self._init_ui()

    def _on_mode_change_callback(self, mode):
        self.mode_changed_signal.emit(mode)

    def _on_telemetry_callback(self, data):
        self.telemetry_signal.emit(data)

    # ── Orijinal sol kontrol paneli (değişiklik yok) ──────────────────────
    def _build_left_panel(self):
        panel = QWidget()
        panel.setStyleSheet("background:#1a1a2e;")
        layout = QVBoxLayout(panel)
        layout.setSpacing(10)
        layout.setContentsMargins(16, 16, 12, 16)

        title = QLabel("IHA UCUS MODU KONTROL PANELI")
        title.setAlignment(Qt.AlignCenter)
        title.setFont(QFont("Arial", 15, QFont.Bold))
        title.setStyleSheet("color:#a0c4ff; margin-bottom:4px;")
        layout.addWidget(title)

        # Bağlantı
        conn_group = QGroupBox("Baglanti Ayarlari")
        conn_layout = QHBoxLayout(conn_group)
        self.conn_input = QLineEdit("tcp:127.0.0.1:5762")
        conn_layout.addWidget(self.conn_input)
        self.connect_btn = QPushButton("Baglan")
        self.connect_btn.setStyleSheet("background:#0f3460;")
        self.connect_btn.clicked.connect(self.connect_clicked)
        conn_layout.addWidget(self.connect_btn)
        self.disconnect_btn = QPushButton("Baglanti Kes")
        self.disconnect_btn.setStyleSheet("background:#7f1d1d;")
        self.disconnect_btn.clicked.connect(self.disconnect_clicked)
        self.disconnect_btn.setEnabled(False)
        conn_layout.addWidget(self.disconnect_btn)
        layout.addWidget(conn_group)

        # Mod + ARM
        top_row = QHBoxLayout()
        mode_display_group = QGroupBox("Mevcut Mod")
        mdl = QVBoxLayout(mode_display_group)
        self.current_mode_label = QLabel("---")
        self.current_mode_label.setAlignment(Qt.AlignCenter)
        self.current_mode_label.setFont(QFont("Arial", 20, QFont.Bold))
        self.current_mode_label.setStyleSheet(
            "color:#f1c40f; background:#16213e; border-radius:8px; padding:8px;")
        mdl.addWidget(self.current_mode_label)
        top_row.addWidget(mode_display_group)

        arm_status_group = QGroupBox("Arm Durumu")
        asl = QVBoxLayout(arm_status_group)
        self.arm_status_label = QLabel("DISARMED")
        self.arm_status_label.setAlignment(Qt.AlignCenter)
        self.arm_status_label.setFont(QFont("Arial", 20, QFont.Bold))
        self.arm_status_label.setStyleSheet(
            "color:#e74c3c; background:#16213e; border-radius:8px; padding:8px;")
        asl.addWidget(self.arm_status_label)
        top_row.addWidget(arm_status_group)
        layout.addLayout(top_row)

        # Göstergeler
        gauges_group = QGroupBox("Ucus Gostergeleri")
        gauges_layout = QHBoxLayout(gauges_group)
        gauges_layout.setSpacing(10)
        self.airspeed_gauge  = GaugeWidget("HAVA HIZI", "m/s", 0, 60)
        self.altitude_gauge  = GaugeWidget("IRTIFA (Bagil)", "metre", 0, 300)
        self.attitude_widget = AttitudeWidget()
        self.status_widget   = StatusWidget()
        for w in (self.airspeed_gauge, self.altitude_gauge,
                  self.attitude_widget, self.status_widget):
            gauges_layout.addWidget(w)
        layout.addWidget(gauges_group)

        # ARM / DISARM
        arm_group = QGroupBox("Arm Kontrol")
        arm_layout = QHBoxLayout(arm_group)
        self.arm_btn = QPushButton("ARM")
        self.arm_btn.setMinimumHeight(48)
        self.arm_btn.setStyleSheet("""
            QPushButton { background:#27ae60; font-size:15px; }
            QPushButton:hover { background:white; color:#27ae60; border:2px solid #27ae60; }
            QPushButton:disabled { background:#444; color:#888; }""")
        self.arm_btn.clicked.connect(self.arm_clicked)
        self.arm_btn.setEnabled(False)
        arm_layout.addWidget(self.arm_btn)
        self.disarm_btn = QPushButton("DISARM")
        self.disarm_btn.setMinimumHeight(48)
        self.disarm_btn.setStyleSheet("""
            QPushButton { background:#c0392b; font-size:15px; }
            QPushButton:hover { background:white; color:#c0392b; border:2px solid #c0392b; }
            QPushButton:disabled { background:#444; color:#888; }""")
        self.disarm_btn.clicked.connect(self.disarm_clicked)
        self.disarm_btn.setEnabled(False)
        arm_layout.addWidget(self.disarm_btn)
        layout.addWidget(arm_group)

        # Mod butonları
        modes_group = QGroupBox("Mod Sec ve Degistir")
        modes_layout = QVBoxLayout(modes_group)
        row = None
        for i, (mode, color, tooltip) in enumerate(self.MODES):
            if i % 2 == 0:
                row = QHBoxLayout()
                modes_layout.addLayout(row)
            btn = QPushButton(mode)
            btn.setToolTip(tooltip)
            btn.setMinimumHeight(44)
            btn.setStyleSheet(f"""
                QPushButton {{ background:{color}; font-size:13px; }}
                QPushButton:hover {{ background:white; color:{color}; border:2px solid {color}; }}
                QPushButton:disabled {{ background:#444; color:#888; }}""")
            btn.clicked.connect(lambda checked, m=mode: self.set_mode_clicked(m))
            btn.setEnabled(False)
            self.mode_buttons_dict[mode] = btn
            row.addWidget(btn)

        custom_row = QHBoxLayout()
        self.custom_mode_input = QComboBox()
        self.custom_mode_input.setEditable(True)
        self.custom_mode_input.addItems([m[0] for m in self.MODES] + self.EXTRA_MODES)
        self.custom_mode_input.setStyleSheet(
            "background:#16213e; color:white; border:1px solid #0f3460;"
            "border-radius:5px; padding:5px; font-size:13px;")
        self.custom_apply_btn = QPushButton("Ozel Mod Uygula")
        self.custom_apply_btn.setStyleSheet("background:#0f3460;")
        self.custom_apply_btn.clicked.connect(
            lambda: self.set_mode_clicked(
                self.custom_mode_input.currentText().upper().strip()))
        self.custom_apply_btn.setEnabled(False)
        custom_row.addWidget(QLabel("Ozel:"))
        custom_row.addWidget(self.custom_mode_input)
        custom_row.addWidget(self.custom_apply_btn)
        modes_layout.addLayout(custom_row)
        layout.addWidget(modes_group)

        return panel

