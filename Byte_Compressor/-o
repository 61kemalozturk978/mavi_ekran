class StatusWidget(QWidget):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.satellites  = 0
        self.rssi        = 0
        self.rssi_active = False
        self.setMinimumSize(140, 180)

    def set_data(self, satellites, rssi, rssi_active=False):
        self.satellites  = satellites
        self.rssi        = rssi
        self.rssi_active = rssi_active
        self.update()

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.Antialiasing)
        w = self.width(); h = self.height()

        painter.setBrush(QBrush(QColor("#16213e")))
        painter.setPen(QPen(QColor("#0f3460"), 2))
        painter.drawRoundedRect(2, 2, w - 4, h - 4, 10, 10)

        painter.setPen(QColor("#a0c4ff"))
        painter.setFont(QFont("Arial", 9, QFont.Bold))
        painter.drawText(QRectF(0, 10, w, 18), Qt.AlignCenter, "GPS UYDU")

        sat_color = (QColor("#2ecc71") if self.satellites >= 8
                     else QColor("#f39c12") if self.satellites >= 5
                     else QColor("#e74c3c"))
        painter.setPen(sat_color)
        painter.setFont(QFont("Arial", 28, QFont.Bold))
        painter.drawText(QRectF(0, 28, w, 44), Qt.AlignCenter, str(self.satellites))
        painter.setPen(QColor("#888"))
        painter.setFont(QFont("Arial", 8))
        painter.drawText(QRectF(0, 70, w, 16), Qt.AlignCenter, "uydu")

        painter.setPen(QPen(QColor("#0f3460"), 1))
        painter.drawLine(int(w * 0.1), 92, int(w * 0.9), 92)
        painter.setPen(QColor("#a0c4ff"))
        painter.setFont(QFont("Arial", 9, QFont.Bold))
        painter.drawText(QRectF(0, 98, w, 18), Qt.AlignCenter, "RSSI")

        bar_count = 5
        single_w  = (w - 20 - 4 * (bar_count - 1)) / bar_count

        if not self.rssi_active:
            painter.setPen(QColor("#555"))
            painter.setFont(QFont("Arial", 8))
            painter.drawText(QRectF(0, 118, w, 20), Qt.AlignCenter, "Radyo Yok")
            painter.setPen(Qt.NoPen)
            for i in range(bar_count):
                bx = 10 + i * (single_w + 4); bh = 6 + i * 5; by = h - 14 - bh
                painter.setBrush(QBrush(QColor("#333")))
                painter.drawRoundedRect(int(bx), int(by), int(single_w), int(bh), 2, 2)
        else:
            rssi_ratio = min(1.0, self.rssi / 254.0)
            bar_w = int((w - 20) * rssi_ratio); bar_y = 122
            rssi_color = (QColor("#2ecc71") if rssi_ratio > 0.6
                          else QColor("#f39c12") if rssi_ratio > 0.3
                          else QColor("#e74c3c"))
            painter.setBrush(QBrush(QColor("#1a1a2e")))
            painter.setPen(Qt.NoPen)
            painter.drawRoundedRect(10, bar_y, w - 20, 16, 4, 4)
            if bar_w > 0:
                painter.setBrush(QBrush(rssi_color))
                painter.drawRoundedRect(10, bar_y, bar_w, 16, 4, 4)
            painter.setPen(QColor("white"))
            painter.setFont(QFont("Arial", 8, QFont.Bold))
            painter.drawText(QRectF(0, bar_y, w, 16), Qt.AlignCenter, f"{self.rssi}/254")
            painter.setPen(Qt.NoPen)
            for i in range(bar_count):
                bx = 10 + i * (single_w + 4); bh = 6 + i * 5; by = h - 14 - bh
                filled = rssi_ratio > (i / bar_count)
                painter.setBrush(QBrush(rssi_color if filled else QColor("#333")))
                painter.drawRoundedRect(int(bx), int(by), int(single_w), int(bh), 2, 2)


